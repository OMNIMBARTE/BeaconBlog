<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    <title>Blogify — Create account</title>
</head>
<body>
    <%- include('./partials/nav') %>

    <main class="auth-wrap">
        <span class="eyebrow">Join the desk</span>
        <h1>Create your account</h1>
        <p class="sub">Get your own byline in three fields.</p>

        <div class="auth-card">
            <form action="/user/signup" method="post">
                <div class="field">
                    <label for="fullname">Full name</label>
                    <input type="text" id="fullname" name="fullname" placeholder="Jane Doe" value="<%= locals.fullname || '' %>" required>
                </div>
                <div class="field">
                    <label for="email">Email address</label>
                    <input type="email" id="email" name="email" placeholder="you@example.com" value="<%= locals.email || '' %>" required>
                    <p class="field-help">We'll never share your email with anyone else.</p>
                </div>
                <div class="field">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" placeholder="••••••••" required>
                </div>
                <button type="submit">Create account</button>
            </form>
        </div>

        <p class="auth-switch">Already have an account? <a href="/user/signin">Sign in</a></p>
    </main>

    <%- include('./partials/script') %>
</body>
</html>
